{
  "name": "mcp-browser-console-workspace",
  "version": "0.1.1",
  "private": true,
  "description": "Monorepo for a Chrome Extension and MCP server that streams browser console and network events to AI tools.",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "node scripts/run-workspaces.mjs build",
    "clean": "node scripts/run-workspaces.mjs clean",
    "dev:extension": "node scripts/run-workspaces.mjs dev @mcp-browser-console/extension",
    "dev:server": "node scripts/run-workspaces.mjs dev @rekl0w/mcp-browser-console",
    "pack:server": "npm pack --workspace @rekl0w/mcp-browser-console",
    "publish:server": "npm publish --workspace @rekl0w/mcp-browser-console --access public",
    "test": "node scripts/test.mjs",
    "test:server": "node scripts/smoke-server.mjs",
    "typecheck": "node scripts/run-workspaces.mjs typecheck"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "rimraf": "6.1.3",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  }
}
